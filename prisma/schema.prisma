generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── COUPLE ──────────────────────────────────────────────────────────────────

model Couple {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  prenoms   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weddingDate    DateTime?
  weddingCity    String?
  weddingVenue   String?
  guestCount     Int?
  budgetEstimate Int?
  ambiances      String[]
  planningStage  String?
  onboardingDone Boolean @default(false)

  tasks              CoupleTask[]
  guests             Guest[]
  conversations      Conversation[]
  payments           Payment[]
  vendorRelations    VendorRelation[]
  cagnotte           Cagnotte?
  manualVendorEntries ManualVendorEntry[]

  @@map("couples")
}

// ─── PRESTATAIRE ─────────────────────────────────────────────────────────────

model Pro {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  status      ProStatus @default(PENDING)
  validatedAt DateTime?

  slug        String  @unique
  name        String
  tagline     String?
  bio         String? @db.Text
  category    ProCategory
  ambiances   String[]
  styleKeywords String[]
  city        String?
  department  String?
  radiusKm    Int     @default(80)

  stripeAccountId String? @unique
  stripeOnboarded Boolean @default(false)

  profilePhoto    String?
  portfolioPhotos String[]
  calendarActive  Boolean @default(false)

  // Fiche enrichie
  specs         Json?    // champs structurés par catégorie
  highlightText String?  // "Le plus" affiché dans l'aside
  ctaLabel      String?  // label du bouton CTA or (ex: "Voir le portfolio")
  ctaUrl        String?  // URL du CTA (site, SoundCloud, mix…)

  tarifs              ProTarif[]
  availability        ProAvailability[]
  manualVendorEntries ManualVendorEntry[]
  conversations Conversation[]
  payments      Payment[]
  paymentLinks    PaymentLink[]
  stats           ProStats?
  tasks           CoupleTask[]
  vendorRelations VendorRelation[]

  @@map("pros")
}

enum ProStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ProCategory {
  PHOTOGRAPHE
  VIDEASTE
  TRAITEUR
  LIEU
  FLEURISTE
  DJ_MUSICIEN
  OFFICIANT
  COIFFURE_MAQUILLAGE
  DECORATION_PAPETERIE
  WEDDING_PLANNER
  VINS_CHAMPAGNE
  VOITURE_TRANSPORT
  ROBE_COSTUME
  PHOTOBOOTH
  ONGLES_MANUCURE
  GOODIES_INVITES
  SOINS_PRE_MARIAGE
  AUTRE
}

model ProTarif {
  id          String @id @default(cuid())
  proId       String
  pro         Pro    @relation(fields: [proId], references: [id], onDelete: Cascade)
  name        String
  description String?
  priceFrom   Int
  position    Int    @default(0)

  @@map("pro_tarifs")
}

model ProAvailability {
  id     String             @id @default(cuid())
  proId  String
  pro    Pro                @relation(fields: [proId], references: [id], onDelete: Cascade)
  date   DateTime           @db.Date
  status AvailabilityStatus

  @@unique([proId, date])
  @@map("pro_availability")
}

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
}

model ProStats {
  id           String @id @default(cuid())
  proId        String @unique
  pro          Pro    @relation(fields: [proId], references: [id], onDelete: Cascade)
  profileViews Int    @default(0)
  messageCount Int    @default(0)

  @@map("pro_stats")
}

// ─── TÂCHES DU CARNET ────────────────────────────────────────────────────────

model CoupleTask {
  id        String   @id @default(cuid())
  coupleId  String
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phase       Int
  position    Int
  category    String
  title       String
  description String?
  timingLabel String?
  tipContext   String?

  status     TaskStatus @default(TODO)

  proId      String?
  pro        Pro?    @relation(fields: [proId], references: [id])
  proName    String?
  quoteTotal Int?

  payments   Payment[]

  @@map("couple_tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

// ─── INVITÉS ─────────────────────────────────────────────────────────────────

model Guest {
  id        String   @id @default(cuid())
  coupleId  String
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  firstName String
  lastName  String
  address   String?
  diet      String?
  presence  GuestPresence @default(PENDING)
  notes     String?

  @@map("guests")
}

enum GuestPresence {
  PRESENT
  ABSENT
  PENDING
}

// ─── MESSAGERIE ──────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coupleId String
  couple   Couple @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  proId    String
  pro      Pro    @relation(fields: [proId], references: [id], onDelete: Cascade)

  messages       Message[]
  unreadByCouple Int @default(0)
  unreadByPro    Int @default(0)

  @@unique([coupleId, proId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  senderRole SenderRole
  body       String     @db.Text
  emailSent  Boolean    @default(false)

  @@map("messages")
}

enum SenderRole {
  COUPLE
  PRO
}

// ─── PAIEMENTS ───────────────────────────────────────────────────────────────
// =====================================================
// TABLES DÉSACTIVÉES POUR LE MVP — réactivation prévue en V2
//
// Les tables suivantes sont conservées dans le schéma mais ne sont
// plus alimentées par l'UI :
//   - payments      (paiements Stripe Connect entre couple et prestataire)
//   - payment_links (liens de paiement créés par les pros)
//
// Si tu travailles sur ce code en V2, lis :
//   PROMPT-DESACTIVATION-PAIEMENT.md
//   PROMPT-PAIEMENT-RATTACHEMENT.md
// =====================================================

model PaymentLink {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proId String
  pro   Pro    @relation(fields: [proId], references: [id], onDelete: Cascade)

  coupleEmail String
  coupleName  String

  label       String
  type        PaymentLinkType
  quoteTotal  Int
  amount      Int
  amountTotal Int
  message     String? @db.Text

  stripePaymentIntentId String? @unique
  stripePaymentUrl      String?

  status    PaymentLinkStatus @default(PENDING)
  expiresAt DateTime
  paidAt    DateTime?

  payment Payment?

  @@map("payment_links")
}

enum PaymentLinkType {
  ACOMPTE
  SOLDE
  UNIQUE
  ECHEANCE
}

enum PaymentLinkStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

model Payment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  coupleId      String?
  couple        Couple?     @relation(fields: [coupleId], references: [id])
  proId         String?
  pro           Pro?        @relation(fields: [proId], references: [id])
  taskId        String?
  task          CoupleTask? @relation(fields: [taskId], references: [id])
  paymentLinkId String?     @unique
  paymentLink   PaymentLink? @relation(fields: [paymentLinkId], references: [id])

  amount     Int
  amountNet  Int
  commission Int
  stripeFee  Int
  currency   String @default("eur")

  type    PaymentType
  status  PaymentStatus @default(PENDING)
  label   String?
  notes   String?

  stripePaymentIntentId String? @unique
  receiptUrl            String?

  @@map("payments")
}

enum PaymentType {
  PLATFORM
  MANUAL
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─── RELATIONS PRESTATAIRES ──────────────────────────────────────────────────

model VendorRelation {
  id        String               @id @default(cuid())
  coupleId  String
  couple    Couple               @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  proId     String
  pro       Pro                  @relation(fields: [proId], references: [id], onDelete: Cascade)
  status    VendorRelationStatus
  category  String               // dénormalisé pour requêtes rapides par catégorie
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([coupleId, proId])
  @@map("vendor_relations")
}

enum VendorRelationStatus {
  FAVORITE
  RETAINED
}

// ─── CAGNOTTE ────────────────────────────────────────────────────────────────

model Cagnotte {
  id        String        @id @default(cuid())
  coupleId  String        @unique
  couple    Couple        @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  slug      String        @unique
  title     String        @default("")
  subtitle  String?
  story     String?       @db.Text
  photoUrl  String?

  status    CagnotteStatus @default(DRAFT)

  // Réglages
  showGuestbook    Boolean @default(true)
  allowAnonymous   Boolean @default(true)
  emailOnDonation  Boolean @default(true)
  emailWeeklyRecap Boolean @default(true)

  // Retrait
  ibanStored      String?
  withdrawnAt     DateTime?

  dreams      CagnotteDream[]
  program     CagnotteProgram[]
  donations   CagnotteDonation[]
  withdrawals CagnotteWithdrawal[]

  @@map("cagnottes")
}

enum CagnotteStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model CagnotteDream {
  id          String    @id @default(cuid())
  cagnotteId  String
  cagnotte    Cagnotte  @relation(fields: [cagnotteId], references: [id], onDelete: Cascade)
  title       String
  description String?   @db.Text
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  donations   CagnotteDonation[]

  @@map("cagnotte_dreams")
}

model CagnotteProgram {
  id          String    @id @default(cuid())
  cagnotteId  String
  cagnotte    Cagnotte  @relation(fields: [cagnotteId], references: [id], onDelete: Cascade)
  timeLabel   String
  description String
  sortOrder   Int       @default(0)

  @@map("cagnotte_program")
}

model CagnotteDonation {
  id          String         @id @default(cuid())
  cagnotteId  String
  cagnotte    Cagnotte       @relation(fields: [cagnotteId], references: [id], onDelete: Cascade)
  dreamId     String?
  dream       CagnotteDream? @relation(fields: [dreamId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())

  donorName   String?
  donorEmail  String
  isAnonymous Boolean  @default(false)
  message     String?  @db.Text

  amountNet        Int  // centimes — montant pour le couple
  amountStripeFees Int  // centimes — frais Stripe facturés à l'invité
  amountTotalPaid  Int  // centimes — total payé par l'invité

  stripePaymentIntentId String?  @unique
  status    DonationStatus @default(PENDING)
  paidAt    DateTime?

  @@map("cagnotte_donations")
}

enum DonationStatus {
  PENDING
  PAID
  REFUNDED
}

model CagnotteWithdrawal {
  id          String    @id @default(cuid())
  cagnotteId  String
  cagnotte    Cagnotte  @relation(fields: [cagnotteId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  amountGross       Int  // brut cagnotte en centimes
  platformCommission Int  // 3%
  stripePayout      Int  // 25 centimes
  amountNet         Int  // net reçu

  ibanSnapshot String?   // IBAN au moment du retrait
  status       WithdrawalStatus @default(REQUESTED)
  completedAt  DateTime?

  @@map("cagnotte_withdrawals")
}

enum WithdrawalStatus {
  REQUESTED
  PROCESSING
  COMPLETED
  FAILED
}

// ─── SAISIE MANUELLE BUDGET ──────────────────────────────────────────────────

model ManualVendorEntry {
  id        String   @id @default(cuid())
  coupleId  String
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  // Cas B : lié à un Pro de la plateforme (null = Cas C)
  proId     String?
  pro       Pro?     @relation(fields: [proId], references: [id], onDelete: SetNull)
  isExternal Boolean @default(false) // false = Cas B, true = Cas C

  // Identité (toujours rempli — copié du Pro pour Cas B, saisi pour Cas C)
  vendorName     String
  vendorCategory String
  vendorCity     String?
  vendorEmail    String?
  vendorPhone    String?
  vendorWebsite  String?

  // Devis (en centimes — obligatoire)
  totalAmount    Int
  prestationDate DateTime? @db.Date

  // Suivi paiement
  status         ManualEntryStatus @default(QUOTED)
  depositAmount  Int               @default(0)
  depositPaidAt  DateTime?         @db.Date
  balanceDueDate DateTime?         @db.Date
  paymentMethod  String?           // check | transfer | cash | other

  // Preuve (Cloudinary URL — Supabase Storage en V2)
  proofUrl       String?

  notes          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("manual_vendor_entries")
}

enum ManualEntryStatus {
  DISCUSSING
  QUOTED
  DEPOSIT_PAID
  FULLY_PAID
}

// ─── CONTENU ÉDITORIAL ───────────────────────────────────────────────────────

model Tip {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  context  String
  position Int     @default(0)
  body     String  @db.Text
  active   Boolean @default(true)

  @@map("tips")
}

// ─── RÉINITIALISATION MOT DE PASSE ───────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  role      String    // "couple" | "pro"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

// ─── ADMIN ───────────────────────────────────────────────────────────────────

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  @@map("admins")
}
