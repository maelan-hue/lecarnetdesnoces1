{
  "permissions": {
    "allow": [
      "Bash(export PATH=\"$PATH:/usr/local/bin:/opt/homebrew/bin:/usr/bin\")",
      "Read(//opt/**)",
      "Read(//Applications/**)",
      "Bash(/opt/homebrew/bin/node --version)",
      "Bash(/opt/homebrew/bin/npm --version)",
      "Bash(/opt/homebrew/bin/brew list *)",
      "Bash(npm --version)",
      "Bash(npx --version)",
      "Bash(npx create-next-app@latest *)",
      "Bash(npm install *)",
      "Bash(npx prisma *)",
      "Bash(npx tsc *)",
      "Bash(npx next *)",
      "Bash(node *)",
      "Bash(npm run *)",
      "Bash(curl -s http://localhost:3000)",
      "Bash(pkill -f \"next dev\")",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(npm uninstall *)",
      "Bash(kill 4810)",
      "Bash(pkill -9 -f \"next\")",
      "Bash(pkill -9 -f \"node\")",
      "Bash(lsof -ti:3000 -ti:3001 -ti:3002)",
      "Bash(xargs kill *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/)",
      "Bash(kill %1)"
    ]
  }
}
