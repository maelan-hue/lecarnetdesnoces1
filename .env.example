# Base de données — Neon PostgreSQL
# Créer un compte sur https://neon.tech → New Project → copier la connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT — clé secrète aléatoire (minimum 32 caractères)
# Générer avec : openssl rand -base64 32
JWT_SECRET="remplacer-par-une-cle-secrete-longue-et-aleatoire"

# Resend — emails transactionnels
# Créer un compte sur https://resend.com → API Keys → Create API Key
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM="Le Carnet des noces <contact@lecarnetdesnoces.fr>"

# Stripe
# Créer un compte sur https://stripe.com → Developers → API keys
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

# Cloudinary — stockage images portfolio
# Créer un compte sur https://cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME="votre-cloud-name"
CLOUDINARY_API_KEY="xxxxxxxxxxxx"
CLOUDINARY_API_SECRET="xxxxxxxxxxxx"

# URL du site (sans slash final)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Commission plateforme (en pourcentage entier)
NEXT_PUBLIC_COMMISSION_PCT="3"
